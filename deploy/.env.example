# نطاقك (يجب أن يشير DNS الخاص به إلى IP الخادم) — مطلوب لتفعيل HTTPS
DOMAIN=app.example.com

# سرّ توقيع الجلسات — ضع سلسلة عشوائية طويلة (مثال: openssl rand -hex 32)
JWT_SECRET=

# نطاقات CORS المسموح بها (افصل بفاصلة). اتركه فارغاً للسماح للكل
# (الـ API محمي بـ JWT، لكن تطبيق أندرويد يرسل من أصل https://localhost)
CORS_ORIGINS=
