rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Login-lockout counter. Must be reachable BEFORE auth (failed logins aren't signed in).
    // Unauthenticated callers may only create with count==1 or raise the counter by exactly 1,
    // and `blocked` is forced to match the count threshold — they can never clear/unblock it.
    // Signed-in callers (admin unblock + post-login reset) have full control.
    match /web_login_attempts/{key} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth == null
        && request.resource.data.count == 1
        && request.resource.data.blocked == false;
      allow update: if request.auth == null
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.blocked == (request.resource.data.count >= 3)
        && request.resource.data.email == resource.data.email;
    }

    // Any signed-in user of the system has full access.
    // (Per-role restrictions can be layered on later.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
