# ===== إعدادات خادم أم فارس (Umfaris API) =====
# انسخ هذا الملف إلى .env وعدّل القيم. لا تشارك ملف .env إطلاقاً.

# مفتاح توقيع جلسات الدخول (JWT). يجب أن يكون نصاً عشوائياً طويلاً وسرياً.
# لتوليد مفتاح جديد:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ضع_هنا_مفتاحاً_عشوائياً_طويلاً

# منفذ الخادم
PORT=4000

# مسار ملف قاعدة البيانات (اتركه فارغاً للمسار الافتراضي server/data.db)
DB_PATH=

# نطاقات مسموح لها بالوصول (CORS) مفصولة بفاصلة. اتركه فارغاً للسماح للجميع (أثناء التطوير فقط).
# مثال للإنتاج: CORS_ORIGINS=https://app.umfaris.com,https://umfaris.com
CORS_ORIGINS=
